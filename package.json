{
  "name": "zando243-ecommerce-ssr",
  "version": "1.0.0",
  "description": "Plateforme e-commerce SSR Express/EJS/PostgreSQL/Sequelize",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "migrate": "sequelize-cli db:migrate --config src/config/sequelize-cli.cjs",
    "seed": "sequelize-cli db:seed:all --config src/config/sequelize-cli.cjs",
    "pretest": "node -e \"require('./tests/_setup-test-db').ensureTestDatabaseExists().then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); })\"",
    "test": "node --test --test-concurrency=1 tests/*.test.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-auth": "^1.6.11",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.0",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.6",
    "pdfkit": "^0.15.0",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "sanitize-html": "^2.17.3",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.2",
    "slugify": "^1.6.6",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "pino-pretty": "^11.3.0"
  }
}
