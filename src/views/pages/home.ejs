<%- include('../partials/head', { title, metaDescription: 'Accueil marketplace' }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>
<main class="container-max mx-auto px-4 py-6 space-y-8">
  <section class="rounded-2xl overflow-hidden bg-gradient-to-r from-blue-700 to-blue-500 text-white p-6 md:p-10">
    <div class="max-w-xl">
      <p class="text-xs uppercase tracking-widest mb-2">Marketplace Zando243</p>
      <h1 class="text-3xl md:text-4xl font-extrabold">Votre raccourci vers le monde</h1>
      <p class="mt-3 text-blue-100">Accedez facilement a une large selection de produits, commandez en quelques clics et suivez vos achats en toute confiance.</p>
      <div class="mt-5 flex gap-3">
        <a class="btn-primary bg-white !text-blue-700" href="/products">Explorer les produits</a>
        <a class="btn-secondary bg-blue-800/40 !text-white border border-blue-300/30" href="/cart">Voir mon panier</a>
      </div>
    </div>
  </section>
  <section>
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-bold">Categories</h2>
      <a href="/products" class="text-blue-700 font-semibold">Tout voir</a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% categories.slice(0,8).forEach(cat => { %>
        <a href="/categories/<%= cat.slug %>" class="card p-4 hover:shadow-md transition">
          <div class="font-semibold"><%= cat.name %></div>
          <div class="text-xs text-slate-500 mt-1">Slug: <%= cat.slug %></div>
        </a>
      <% }) %>
    </div>
  </section>
  <section>
    <h2 class="text-xl font-bold mb-4">Produits recommandes</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% products.forEach(product => { const mainImg=(product.images||[]).find(i=>i.isMain)||(product.images||[])[0]; %>
        <div class="card overflow-hidden hover:shadow-lg transition group">
          <a href="/products/<%= product.slug %>" class="block">
            <div class="aspect-[4/3] bg-slate-100 overflow-hidden">
              <img class="w-full h-full object-cover transition duration-300 group-hover:scale-[1.03]" src="<%= mainImg?.url || 'https://via.placeholder.com/600x400' %>" alt="">
            </div>
          </a>
          <div class="p-3 space-y-3">
            <div>
              <a href="/products/<%= product.slug %>" class="text-sm font-semibold line-clamp-2 hover:text-blue-700"><%= product.name %></a>
              <div class="text-xs text-slate-500"><%= product.brand || 'Sans marque' %></div>
              <div class="mt-2 text-blue-700 font-bold">$<%= product.finalPrice %></div>
            </div>
            <div class="flex items-center gap-2">
              <form action="/cart/items" method="POST" class="flex-1">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="productId" value="<%= product.id %>">
                <input type="hidden" name="qty" value="1">
                <button class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700" type="submit">
                  Ajouter
                </button>
              </form>
              <form action="/cart/items" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="productId" value="<%= product.id %>">
                <input type="hidden" name="qty" value="1">
                <input type="hidden" name="redirectTo" value="cart">
                <button
                  class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-blue-600 text-white transition hover:bg-blue-700"
                  type="submit"
                  title="Acheter maintenant">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="9" cy="20" r="1"></circle>
                    <circle cx="18" cy="20" r="1"></circle>
                    <path d="M3 4h2l2.4 10.2a1 1 0 0 0 1 .8h9.8a1 1 0 0 0 1-.8L21 7H7"></path>
                  </svg>
                </button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </section>
  <% if (recent?.length) { %>
  <section>
    <h2 class="text-xl font-bold mb-4">Recemment consultes</h2>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
      <% recent.forEach(rv => { const p = rv.product; const mainImg=(p?.images||[]).find(i=>i.isMain)||(p?.images||[])[0]; if (!p) return; %>
        <a href="/products/<%= p.slug %>" class="card p-2">
          <img class="aspect-square w-full object-cover rounded-lg bg-slate-100" src="<%= mainImg?.url || 'https://via.placeholder.com/400' %>" alt="">
          <div class="text-xs mt-2 line-clamp-2"><%= p.name %></div>
        </a>
      <% }) %>
    </div>
  </section>
  <% } %>
</main>
<%- include('../partials/footer') %>
