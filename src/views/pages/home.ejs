<%- include('../partials/head', { title, metaDescription: 'Accueil marketplace' }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>
<main class="container-max mx-auto px-4 py-6 space-y-8">
  <section class="rounded-2xl overflow-hidden bg-gradient-to-r from-blue-700 to-blue-500 text-white p-6 md:p-10">
    <div class="max-w-xl">
      <p class="text-xs uppercase tracking-widest mb-2">Marketplace Zando243</p>
      <h1 class="text-3xl md:text-4xl font-extrabold">Catalogue e-commerce inspiré Amazon / AliExpress</h1>
      <p class="mt-3 text-blue-100">Recherche, panier, commandes, favoris, retours, support, tracking et admin SSR.</p>
      <div class="mt-5 flex gap-3">
        <a class="btn-primary bg-white !text-blue-700" href="/products">Explorer les produits</a>
        <a class="btn-secondary bg-blue-800/40 !text-white border border-blue-300/30" href="/cart">Voir mon panier</a>
      </div>
    </div>
  </section>
  <section>
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-bold">Catégories</h2>
      <a href="/products" class="text-blue-700 font-semibold">Tout voir</a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% categories.slice(0,8).forEach(cat => { %>
        <a href="/categories/<%= cat.slug %>" class="card p-4 hover:shadow-md transition">
          <div class="font-semibold"><%= cat.name %></div>
          <div class="text-xs text-slate-500 mt-1">Slug: <%= cat.slug %></div>
        </a>
      <% }) %>
    </div>
  </section>
  <section>
    <h2 class="text-xl font-bold mb-4">Produits recommandés</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% products.forEach(product => { const mainImg=(product.images||[]).find(i=>i.isMain)||(product.images||[])[0]; %>
        <a href="/products/<%= product.slug %>" class="card overflow-hidden hover:shadow-lg transition">
          <div class="aspect-[4/3] bg-slate-100"><img class="w-full h-full object-cover" src="<%= mainImg?.url || 'https://via.placeholder.com/600x400' %>" alt=""></div>
          <div class="p-3">
            <div class="text-sm font-semibold line-clamp-2"><%= product.name %></div>
            <div class="text-xs text-slate-500"><%= product.brand || 'Sans marque' %></div>
            <div class="mt-2 text-blue-700 font-bold">$<%= product.finalPrice %></div>
          </div>
        </a>
      <% }) %>
    </div>
  </section>
  <% if (recent?.length) { %>
  <section>
    <h2 class="text-xl font-bold mb-4">Récemment consultés</h2>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
      <% recent.forEach(rv => { const p = rv.product; const mainImg=(p?.images||[]).find(i=>i.isMain)||(p?.images||[])[0]; if (!p) return; %>
        <a href="/products/<%= p.slug %>" class="card p-2">
          <img class="aspect-square w-full object-cover rounded-lg bg-slate-100" src="<%= mainImg?.url || 'https://via.placeholder.com/400' %>" alt="">
          <div class="text-xs mt-2 line-clamp-2"><%= p.name %></div>
        </a>
      <% }) %>
    </div>
  </section>
  <% } %>
</main>
<%- include('../partials/footer') %>
