<%- include('../../partials/head', { title }) %><%- include('../../partials/navbar') %><%- include('../../partials/flash') %>
<main class="container-max mx-auto px-4 py-6 grid lg:grid-cols-[240px_1fr] gap-6"><%- include('../../partials/admin-nav') %>
<section class="card p-5">
  <h1 class="text-2xl font-extrabold mb-4">Retours / Remboursements</h1>
  <div class="space-y-3">
    <% returns.forEach(r => { %>
      <div class="border rounded-xl p-4">
        <div class="flex justify-between items-center gap-3">
          <% if (r.Order?.id) { %>
            <a class="text-blue-700 font-semibold" href="/admin/orders/<%= r.Order.id %>"><%= r.Order.orderNumber %></a>
          <% } else { %>
            <strong><%= r.orderId %></strong>
          <% } %>
          <%- include('../../partials/status-badge', { status: r.Order?.status || '' }) %>
        </div>
        <div class="text-sm mt-1"><%= r.reason %></div>
        <div class="text-xs text-slate-500 mt-1">Retour: <span class="font-medium"><%= r.status %></span> • Remboursement uniquement si livraison non effectuee.</div>
      </div>
    <% }) %>
  </div>
</section></main><%- include('../../partials/footer') %>
