<%- include('../../partials/head', { title }) %><%- include('../../partials/navbar') %><%- include('../../partials/flash') %>
<main class="container-max mx-auto px-4 py-6 grid lg:grid-cols-[240px_1fr] gap-6"><%- include('../../partials/admin-nav') %>
<section class="space-y-6">
  <% const addr = (typeof order.addressSnapshot === 'string' ? JSON.parse(order.addressSnapshot) : order.addressSnapshot) || {}; %>
  <% const isDoorDelivery = Number(order.shippingFee || 0) > 0; %>
  <div class="card p-5">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-extrabold"><%= order.orderNumber %></h1>
        <div class="mt-2 flex items-center gap-2">
          <%- include('../../partials/status-badge', { status: order.status }) %>
          <span class="text-sm text-slate-500"><%= new Date(order.createdAt).toLocaleString('fr-FR') %></span>
        </div>
      </div>
      <div class="text-right text-sm space-y-2">
        <div class="font-semibold text-slate-700">Paiement: <%= order.paymentMethod %></div>
        <div class="mt-1">Tracking: <%= order.trackingNumber || '-' %></div>
        <div class="mt-1 text-xs text-slate-500">ITS-D = porte - ITS-R = retrait</div>
        <div class="pt-1 flex flex-wrap justify-end gap-2">
          <a href="/admin/orders/<%= order.id %>/export-pdf" class="px-3 py-2 rounded-xl border border-slate-300 text-slate-700 hover:bg-slate-50 text-xs font-semibold">Telecharger PDF brut</a>
          <a href="/admin/orders/<%= order.id %>/shipping-label" class="px-3 py-2 rounded-xl bg-blue-600 text-white hover:bg-blue-700 text-xs font-semibold">Generer bordereau 10x15</a>
        </div>
      </div>
    </div>
  </div>

  <div class="grid xl:grid-cols-3 gap-6">
    <div class="card p-5">
      <h2 class="font-bold mb-3">Client</h2>
      <div class="space-y-1 text-sm">
        <div><span class="text-slate-500">Nom:</span> <strong><%= order.User ? `${order.User.firstName} ${order.User.lastName}` : '-' %></strong></div>
        <div><span class="text-slate-500">ID client:</span> <code class="text-xs"><%= order.userId %></code></div>
        <div><span class="text-slate-500">Email:</span> <%= order.User?.email || '-' %></div>
        <div><span class="text-slate-500">Telephone:</span> <%= order.User?.phone || '-' %></div>
      </div>
    </div>
    <div class="card p-5">
      <h2 class="font-bold mb-3">Adresse (snapshot)</h2>
      <div class="space-y-1 text-sm">
        <div><span class="text-slate-500">Label:</span> <%= addr.label || '-' %></div>
        <div><span class="text-slate-500">Numero:</span> <%= addr.number || '-' %></div>
        <div><span class="text-slate-500">Rue:</span> <%= addr.street || '-' %></div>
        <div><span class="text-slate-500">Quartier:</span> <%= addr.neighborhood || '-' %></div>
        <div><span class="text-slate-500">Commune:</span> <%= addr.municipality || '-' %></div>
        <div><span class="text-slate-500">Ville:</span> <%= addr.city || '-' %></div>
        <div><span class="text-slate-500">Pays:</span> <%= addr.country || '-' %></div>
      </div>
    </div>
    <div class="card p-5">
      <h2 class="font-bold mb-3">Options de livraison</h2>
      <div class="space-y-2 text-sm">
        <div class="flex items-center justify-between"><span>Livraison a la porte cochee</span><strong class="<%= isDoorDelivery ? 'text-emerald-700' : 'text-slate-700' %>"><%= isDoorDelivery ? 'Oui' : 'Non' %></strong></div>
        <div class="flex items-center justify-between"><span>Supplement porte</span><strong>$<%= Number(order.shippingFee || 0).toFixed(2) %></strong></div>
        <div class="flex items-center justify-between"><span>Reduction</span><strong>$<%= Number(order.discountTotal || 0).toFixed(2) %></strong></div>
        <div class="flex items-center justify-between"><span>Frais douane</span><strong>$<%= Number(order.customsFee || 0).toFixed(2) %></strong></div>
        <div class="flex items-center justify-between border-t pt-2"><span>Total</span><strong class="text-blue-700">$<%= Number(order.total || 0).toFixed(2) %></strong></div>
      </div>
    </div>
  </div>

  <div class="card p-5 table-shell overflow-auto">
    <h2 class="font-bold mb-3">Contenu du panier (snapshot commande)</h2>
    <table>
      <thead>
        <tr><th>Article</th><th>SKU</th><th>Poids (kg)</th><th>Qte</th><th>PU</th><th>Total ligne</th></tr>
      </thead>
      <tbody>
        <% (order.items || []).forEach(item => { const snap=(typeof item.productSnapshot === 'string' ? JSON.parse(item.productSnapshot) : item.productSnapshot) || {}; %>
          <tr>
            <td><%= snap.name || 'Article' %></td>
            <td><%= snap.sku || '-' %></td>
            <td><%= Number(snap.weightKg || 0).toFixed(2) %></td>
            <td><%= item.qty %></td>
            <td>$<%= Number(item.unitPrice || 0).toFixed(2) %></td>
            <td>$<%= Number(item.lineTotal || 0).toFixed(2) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="card p-5">
    <h2 class="font-bold mb-3">Historique de statut</h2>
    <div class="space-y-2">
      <% (order.statusHistory || []).sort((a,b)=> new Date(b.createdAt)-new Date(a.createdAt)).forEach(h => { %>
        <div class="border rounded-xl p-3 text-sm flex items-center justify-between gap-3">
          <div>
            <div><%- include('../../partials/status-badge', { status: h.status }) %></div>
            <div class="mt-1 text-slate-600"><%= h.note || '' %></div>
          </div>
          <div class="text-xs text-slate-500"><%= new Date(h.createdAt).toLocaleString('fr-FR') %></div>
        </div>
      <% }) %>
      <% if (!(order.statusHistory || []).length) { %><div class="text-sm text-slate-500">Aucun historique.</div><% } %>
    </div>
  </div>
</section></main><%- include('../../partials/footer') %>
