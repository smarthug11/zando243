<%- include('../../partials/head', { title }) %><%- include('../../partials/navbar') %><%- include('../../partials/flash') %>
<main class="container-max mx-auto px-4 py-6 grid lg:grid-cols-[240px_1fr] gap-6"><%- include('../../partials/admin-nav') %>
<section class="space-y-6">
  <h1 class="text-2xl font-extrabold">Module logistique</h1>
  <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600">
    <span class="font-semibold">Légende tracking:</span>
    <span class="ml-2"><code class="font-semibold">ITS-D</code> = Livraison à la porte</span>
    <span class="ml-3"><code class="font-semibold">ITS-R</code> = Retrait bureau</span>
  </div>
  <div class="grid md:grid-cols-3 gap-4">
    <div class="card p-4"><div class="text-xs text-slate-500">Suivi colis</div><div class="font-bold">Tracking client + admin</div><div class="text-sm mt-2">NumÃ©ros de suivi et statut historisÃ© par commande.</div></div>
    <div class="card p-4"><div class="text-xs text-slate-500">Consolidation</div><div class="font-bold">RÃ©fÃ©rence de groupage</div><div class="text-sm mt-2">Champ `consolidationReference` par commande.</div></div>
    <div class="card p-4"><div class="text-xs text-slate-500">Douane / poids</div><div class="font-bold">Frais douane & poids/volume</div><div class="text-sm mt-2">Champs `customsFee` + `logisticsMeta` extensibles.</div></div>
  </div>
  <div class="card p-5 table-shell overflow-auto">
    <table><thead><tr><th>Date</th><th>Commande</th><th>Statut</th><th>Tracking</th><th>Consolidation</th><th>Douane</th></tr></thead><tbody>
      <% orders.forEach(o => { %><tr class="hover:bg-slate-50"><td><%= new Date(o.createdAt).toLocaleDateString('fr-FR') %></td><td><a class="text-blue-700 font-semibold" href="/admin/orders/<%= o.id %>"><%= o.orderNumber %></a></td><td><%- include('../../partials/status-badge', { status: o.status }) %></td><td><%= o.trackingNumber || '-' %></td><td><%= o.consolidationReference || '-' %></td><td>$<%= o.customsFee || 0 %></td></tr><% }) %>
    </tbody></table>
  </div>
</section></main><%- include('../../partials/footer') %>

