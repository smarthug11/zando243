<%- include('../../partials/head', { title }) %>
<%- include('../../partials/navbar') %>
<%- include('../../partials/flash') %>
<main class="container-max mx-auto px-4 py-10">
  <div class="max-w-md mx-auto card p-6">
    <h1 class="text-xl font-bold mb-4">Mot de passe oublié</h1>
    <form method="POST" action="/auth/forgot-password" class="space-y-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input class="form-input" type="email" name="email" placeholder="Votre email" required>
      <button class="btn-primary w-full">Demander un reset</button>
    </form>
  </div>
</main>
<%- include('../../partials/footer') %>
