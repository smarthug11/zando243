<%- include('../../partials/head', { title }) %>
<%- include('../../partials/navbar') %>
<%- include('../../partials/flash') %>
<main class="container-max mx-auto px-4 py-10">
  <div class="max-w-md mx-auto card p-6">
    <h1 class="text-2xl font-extrabold mb-4">Connexion</h1>
    <form method="POST" action="/auth/login" class="space-y-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input class="form-input" type="email" name="email" placeholder="Email" required>
      <input class="form-input" type="password" name="password" placeholder="Mot de passe" required>
      <button class="btn-primary w-full">Se connecter</button>
    </form>
    <div class="mt-4 text-sm flex justify-between">
      <a class="text-blue-700" href="/auth/register">Créer un compte</a>
      <a class="text-blue-700" href="/auth/forgot-password">Mot de passe oublié</a>
    </div>
  </div>
</main>
<%- include('../../partials/footer') %>
