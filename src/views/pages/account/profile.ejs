<%- include('../../partials/head', { title }) %>
<%- include('../../partials/navbar') %>
<%- include('../../partials/flash') %>
<main class="container-max mx-auto px-4 py-6 grid lg:grid-cols-[1.2fr_1fr] gap-6">
  <section class="space-y-6">
    <div class="card p-5">
      <h1 class="text-2xl font-extrabold mb-4">Mon profil</h1>
      <form action="/account/profile" method="POST" class="space-y-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="grid grid-cols-2 gap-3">
          <input class="form-input" name="firstName" value="<%= user.firstName %>">
          <input class="form-input" name="lastName" value="<%= user.lastName %>">
        </div>
        <input class="form-input" name="email" type="email" value="<%= user.email %>">
        <input class="form-input" name="phone" value="<%= user.phone || '' %>" placeholder="Téléphone">
        <input class="form-input" name="avatarUrl" value="<%= user.avatarUrl || '' %>" placeholder="Avatar URL">
        <div class="flex items-center justify-between text-sm">
          <span>Points fidélité: <strong><%= user.loyaltyPoints %></strong></span>
          <span>Email vérifié: <strong><%= user.emailVerifiedAt ? 'Oui' : 'Non' %></strong></span>
        </div>
        <button class="btn-primary" type="submit">Enregistrer</button>
      </form>
    </div>
    <div class="card p-5">
      <h2 class="font-bold mb-3">Adresses</h2>
      <div class="space-y-3 mb-4">
        <% addresses.forEach(a => { %>
          <form action="/account/addresses/<%= a.id %>" method="POST" class="border rounded-xl p-3 grid md:grid-cols-3 gap-2">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input class="form-input" name="label" value="<%= a.label %>" placeholder="Label">
            <input class="form-input" name="street" value="<%= a.street %>" placeholder="Rue">
            <input class="form-input" name="city" value="<%= a.city %>" placeholder="Ville">
            <input class="form-input" name="number" value="<%= a.number || '' %>" placeholder="Numéro">
            <input class="form-input" name="neighborhood" value="<%= a.neighborhood || '' %>" placeholder="Quartier">
            <input class="form-input" name="municipality" value="<%= a.municipality || '' %>" placeholder="Commune">
            <input class="form-input" name="country" value="<%= a.country %>" placeholder="Pays">
            <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="isDefault" value="1" <%= a.isDefault ? 'checked' : '' %>> Défaut</label>
            <div class="flex gap-2">
              <button class="btn-secondary" type="submit">Maj</button>
              <button class="btn-secondary" formaction="/account/addresses/<%= a.id %>/delete">Suppr.</button>
            </div>
          </form>
        <% }) %>
      </div>
      <h3 class="font-semibold mb-2">Ajouter une adresse</h3>
      <form action="/account/addresses" method="POST" class="grid md:grid-cols-3 gap-2">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input class="form-input" name="label" placeholder="Label" required>
        <input class="form-input" name="street" placeholder="Rue" required>
        <input class="form-input" name="city" placeholder="Ville" required>
        <input class="form-input" name="number" placeholder="Numéro">
        <input class="form-input" name="neighborhood" placeholder="Quartier">
        <input class="form-input" name="municipality" placeholder="Commune">
        <input class="form-input" name="country" placeholder="Pays" value="RDC">
        <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="isDefault" value="1"> Défaut</label>
        <button class="btn-primary" type="submit">Ajouter</button>
      </form>
    </div>
  </section>
  <aside class="space-y-6">
    <div class="card p-5">
      <h2 class="font-bold mb-3">Notifications</h2>
      <div class="space-y-2">
        <% notifications.forEach(n => { %>
          <div class="border rounded-lg p-3 text-sm">
            <div class="font-medium"><%= n.type %></div>
            <div><%= n.message %></div>
            <div class="text-xs text-slate-500"><%= n.readAt ? 'Lue' : 'Non lue' %></div>
          </div>
        <% }) %>
      </div>
    </div>
    <div class="card p-5">
      <h2 class="font-bold">Raccourcis</h2>
      <div class="mt-3 grid gap-2">
        <a class="btn-secondary text-center" href="/orders">Mes commandes</a>
        <a class="btn-secondary text-center" href="/favorites">Mes favoris</a>
        <a class="btn-secondary text-center" href="/tickets">Support</a>
      </div>
    </div>
  </aside>
</main>
<%- include('../../partials/footer') %>
