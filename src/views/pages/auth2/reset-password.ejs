<%- include('../../partials/head', { title }) %>
<%- include('../../partials/navbar') %>
<%- include('../../partials/flash') %>
<main class="container-max mx-auto px-4 py-10">
  <div class="max-w-md mx-auto card p-6">
    <h1 class="text-xl font-bold mb-4">Réinitialiser le mot de passe</h1>
    <form method="POST" action="/auth2/reset-password" class="space-y-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="token" value="<%= token %>">
      <input class="form-input" type="password" name="password" placeholder="Nouveau mot de passe" minlength="12" required>
      <p class="text-xs text-slate-500">12 caractères minimum.</p>
      <button class="btn-primary w-full">Mettre à jour</button>
    </form>
  </div>
</main>
<%- include('../../partials/footer') %>
