<aside class="card p-4 space-y-2 text-sm h-fit">
  <% const _currentPath = (typeof currentPath !== 'undefined' && currentPath) ? currentPath : ''; %>
  <% const activeClass = (prefix) => (prefix === '/admin' ? _currentPath === '/admin' : _currentPath.startsWith(prefix)) ? 'font-bold text-blue-700' : ''; %>
  <a class="block <%= activeClass('/admin') %>" href="/admin">Dashboard</a>
  <a class="block <%= activeClass('/admin/products') %>" href="/admin/products">Produits</a>
  <a class="block <%= activeClass('/admin/categories') %>" href="/admin/categories">Catégories</a>
  <a class="block <%= activeClass('/admin/orders') %>" href="/admin/orders">Commandes</a>
  <a class="block <%= activeClass('/admin/coupons') %>" href="/admin/coupons">Coupons</a>
  <a class="block <%= activeClass('/admin/reviews') %>" href="/admin/reviews">Avis</a>
  <a class="block <%= activeClass('/admin/refunds') %>" href="/admin/refunds">Retours</a>
  <a class="block <%= activeClass('/admin/users') %>" href="/admin/users">Clients</a>
  <a class="block <%= activeClass('/admin/logistics') %>" href="/admin/logistics">Logistique</a>
  <a class="block <%= activeClass('/admin/logs') %>" href="/admin/logs">Logs</a>
</aside>
